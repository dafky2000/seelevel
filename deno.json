{
  "imports": {
    "preact": "npm:preact@10.26",
    "preact/hooks": "npm:preact@10.26/hooks",
    "preact/jsx-runtime": "npm:preact@10.26/jsx-runtime",
    "uplot": "npm:uplot@1.6.31",
    "leaflet": "npm:leaflet@1.9.4",
    "@geoman-io/leaflet-geoman-free": "npm:@geoman-io/leaflet-geoman-free@2.17.0",
    "esbuild": "npm:esbuild@0.24",
    "@luca/esbuild-deno-loader": "jsr:@luca/esbuild-deno-loader@0.11",
    "@std/assert": "jsr:@std/assert@1",
    "@std/path": "jsr:@std/path@1",
    "@std/fs": "jsr:@std/fs@1"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "lib": [
      "deno.ns",
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "types": [
      "npm:@types/chrome@0.0.332"
    ]
  },
  "fmt": {
    "exclude": [
      "build/",
      "src/panel/data/ns-municipalities.json"
    ]
  }
}
